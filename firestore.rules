rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userId() {
      return request.auth.uid;
    }

    function isAdvisor() {
      return signedIn() && request.auth.token.role == 'advisor';
    }

    function conversationPath(chapterId, conversationId) {
      return /databases/$(database)/documents/chapters/$(chapterId)/conversations/$(conversationId);
    }

    function existingConversation(chapterId, conversationId) {
      return get(conversationPath(chapterId, conversationId));
    }

    function isParticipant(chapterId, conversationId) {
      return signedIn()
        && existingConversation(chapterId, conversationId).data.participants.hasAny([userId()]);
    }

    function directConversationPath(conversationId) {
      return /databases/$(database)/documents/conversations/$(conversationId);
    }

    function existingDirectConversation(conversationId) {
      return get(directConversationPath(conversationId));
    }

    function isDirectParticipant(conversationId) {
      return signedIn()
        && existingDirectConversation(conversationId).data.participants.hasAny([userId()]);
    }

    function validConversationBase(data) {
      return data.keys().hasOnly([
          'participants',
          'lastMessageTimestamp',
          'lastMessageText',
          'lastSenderId',
          'type',
          'name',
          'createdAt',
          'updatedAt'
        ])
        && data.participants is list
        && data.participants.size() >= 2
        && data.participants.hasAny([userId()])
        && data.type in ['direct', 'group'];
    }

    function validConversationCreate() {
      return validConversationBase(request.resource.data)
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time;
    }

    function validConversationUpdate() {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return changed.hasOnly([
          'lastMessageTimestamp',
          'lastMessageText',
          'lastSenderId',
          'name',
          'updatedAt'
        ])
        && request.resource.data.participants == resource.data.participants
        && request.resource.data.type == resource.data.type
        && (!changed.hasAny(['updatedAt']) || request.resource.data.updatedAt == request.time);
    }

    function validMessageCreate(chapterId, conversationId) {
      return request.resource.data.keys().hasOnly([
          'senderId',
          'content',
          'timestamp',
          'status',
          'readBy',
          'deliveredTo'
        ])
        && isParticipant(chapterId, conversationId)
        && request.resource.data.senderId == userId()
        && request.resource.data.content is string
        && request.resource.data.content.size() > 0
        && request.resource.data.content.size() <= 4000
        && request.resource.data.timestamp == request.time
        && request.resource.data.status == 'sent'
        && request.resource.data.readBy is list
        && request.resource.data.readBy.hasOnly([userId()])
        && request.resource.data.deliveredTo is list
        && request.resource.data.deliveredTo.hasOnly([userId()]);
    }

    function validMessageReceiptUpdate() {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      let previousReadBy = resource.data.readBy == null ? [] : resource.data.readBy;
      let nextReadBy = request.resource.data.readBy == null ? [] : request.resource.data.readBy;
      let previousDeliveredTo = resource.data.deliveredTo == null ? [] : resource.data.deliveredTo;
      let nextDeliveredTo = request.resource.data.deliveredTo == null ? [] : request.resource.data.deliveredTo;

      return changed.hasOnly(['status', 'readBy', 'deliveredTo'])
        && request.resource.data.senderId == resource.data.senderId
        && request.resource.data.content == resource.data.content
        && request.resource.data.timestamp == resource.data.timestamp
        && request.resource.data.status in ['sent', 'delivered', 'read']
        && nextReadBy is list
        && nextDeliveredTo is list
        && previousReadBy.toSet().difference(nextReadBy.toSet()).size() == 0
        && previousDeliveredTo.toSet().difference(nextDeliveredTo.toSet()).size() == 0
        && nextReadBy.toSet().difference(previousReadBy.toSet()).hasOnly([userId()])
        && nextDeliveredTo.toSet().difference(previousDeliveredTo.toSet()).hasOnly([userId()]);
    }

    function validUserProfileBase(data) {
      return data.keys().hasOnly([
          'uid',
          'email',
          'displayName',
          'reminders',
          'profile',
          'createdAt',
          'updatedAt'
        ])
        && data.uid == userId()
        && data.email is string
        && data.displayName is string;
    }

    function validUserProfileCreate(data) {
      return validUserProfileBase(data)
        && data.createdAt == request.time
        && data.updatedAt == request.time;
    }

    function validUserProfileUpdate(data) {
      return validUserProfileBase(data)
        && data.createdAt == resource.data.createdAt
        && data.updatedAt == request.time;
    }

    function validDirectConversationBase(data) {
      return data.keys().hasOnly([
          'participants',
          'participantEmails',
          'lastMessageText',
          'lastSenderId',
          'createdAt',
          'updatedAt'
        ])
        && data.participants is list
        && data.participants.size() == 2
        && data.participants.hasAny([userId()])
        && data.participantEmails is list
        && data.participantEmails.size() == 2
        && data.lastMessageText is string
        && data.lastSenderId == userId()
        && data.updatedAt == request.time;
    }

    function validDirectConversationCreate(data) {
      return validDirectConversationBase(data)
        && data.createdAt == request.time;
    }

    function validDirectConversationUpdate(data) {
      return validDirectConversationBase(data)
        && data.createdAt == resource.data.createdAt
        && request.resource.data.participants == resource.data.participants
        && request.resource.data.participantEmails == resource.data.participantEmails;
    }

    function validDirectMessageCreate(conversationId) {
      return request.resource.data.keys().hasOnly([
          'senderId',
          'text',
          'createdAt'
        ])
        && isDirectParticipant(conversationId)
        && request.resource.data.senderId == userId()
        && request.resource.data.text is string
        && request.resource.data.text.size() > 0
        && request.resource.data.text.size() <= 4000
        && request.resource.data.createdAt == request.time;
    }

    match /users/{uid} {
      allow get: if signedIn();
      allow list: if signedIn();
      allow create: if signedIn()
        && uid == userId()
        && validUserProfileCreate(request.resource.data);
      allow update: if signedIn()
        && uid == userId()
        && validUserProfileUpdate(request.resource.data);
      allow delete: if isAdvisor();
    }

    match /conversations/{conversationId} {
      allow get: if signedIn();
      allow list: if signedIn()
        && resource.data.participants.hasAny([userId()]);
      allow create: if signedIn()
        && validDirectConversationCreate(request.resource.data);
      allow update: if signedIn()
        && resource.data.participants.hasAny([userId()])
        && validDirectConversationUpdate(request.resource.data);
      allow delete: if false;

      match /messages/{messageId} {
        allow get, list: if isDirectParticipant(conversationId);
        allow create: if validDirectMessageCreate(conversationId);
        allow update, delete: if false;
      }
    }

    match /chapters/{chapterId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdvisor();

      match /conversations/{conversationId} {
        allow get, list: if signedIn()
          && (resource.data.participants.hasAny([userId()]) || isAdvisor());
        allow create: if signedIn() && validConversationCreate();
        allow update: if signedIn()
          && (resource.data.participants.hasAny([userId()]) || isAdvisor())
          && validConversationUpdate();
        allow delete: if isAdvisor();

        match /messages/{messageId} {
          allow get, list: if isParticipant(chapterId, conversationId) || isAdvisor();
          allow create: if validMessageCreate(chapterId, conversationId) || isAdvisor();
          allow update: if (isParticipant(chapterId, conversationId) && validMessageReceiptUpdate()) || isAdvisor();
          allow delete: if isAdvisor();
        }
      }
    }
  }
}
